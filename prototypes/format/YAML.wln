   <|"Data" -> "ClearAll[parseNotebook];\n\nparseNotebook[path_] := \
Module[{timeout = 10, temp, notebookHeader, buffer, file = OpenRead[path, \
BinaryFormat->True], list = {}, keys = <||>}, With[{\n  testIfEnd = \
Function[p, StringMatchQ[ReadString[file, \"\\n\", TimeConstraint->timeout], \
StartOfString~~p~~\"%\"~~___]]\n},\n  temp = Check[ReadString[file, \
___~~\"%\"~~Repeated[\"-\", {17,100}]~~\"%Notebook%\"~~Repeated[\"-\", \
{17,100}]~~\"%\"~~EndOfLine, TimeConstraint->timeout], $Failed];\n  \
If[FailureQ[temp], Close[file]; Return[$Failed]];\n  \n  temp = \
Check[ReadString[file, StartOfLine~~\"%\"~~Repeated[\"-\", \
{17,100}]~~Repeated[\"-\", {17,100}]~~\"%\"~~EndOfLine, \
TimeConstraint->timeout], $Failed];\n  If[FailureQ[temp], Close[file]; \
Return[$Failed]];\n  notebookHeader = parseMiniYAML[StringTrim[temp]];\n\n  \
Do[With[{field = field},\n\n  list = {};\n  temp = Check[ReadString[file, \
StartOfLine~~\"%\"~~Repeated[\"-\", \
{17,100}]~~\"%\"~~field~~\"%\"~~Repeated[\"-\", \
{17,100}]~~\"%\"~~EndOfLine~~(\"\\n\"..), TimeConstraint->timeout], \
$Failed];\n  If[FailureQ[temp], Close[file]; Return[$Failed]];\n\n\n  temp = \
Check[ReadString[file, (StartOfLine~~\"%\"~~Repeated[\"-\", \
{17,100}]~~Repeated[\"-\", {17,100}]~~\"%\"~~EndOfLine~~\"\\n\") | \
(StartOfLine~~\"%\"~~Repeated[\"-\", \
{17,100}]~~\"%EndOf\"~~field~~\"%\"~~Repeated[\"-\", \
{17,100}]~~\"%\"~~EndOfLine~~\"\\n\"), TimeConstraint->timeout], $Failed];\n  \
\n  If[FailureQ[temp], Close[file]; Return[$Failed]];\n\n\n  \
If[StringLength[StringTrim[temp]] == 0, \n    keys[field] = {};\n    \
Continue[];\n  ];\n  \n\n  temp = parseMiniYAML[StringTrim[temp]];\n\n  \
buffer = ReadString[file, \"\\n\\n\"~~StartOfLine~~\"%\"~~Repeated[\"-\", \
{16,100}]~~\"%\", TimeConstraint->timeout];\n  If[FailureQ[buffer], \
Close[file]; Return[$Failed]];\n  \n  AppendTo[list, Append[temp, \
\"Data\"->buffer]];\n\n  While[!testIfEnd[\"EndOf\"<>field],\n      temp = \
Check[ReadString[file, StartOfLine~~\"%\"~~Repeated[\"-\", \
{17,100}]~~Repeated[\"-\", {17,100}]~~\"%\"~~EndOfLine~~(\"\\n\"), \
TimeConstraint->timeout], $Failed];\n      If[FailureQ[temp], Close[file]; \
Return[$Failed]];\n\n      temp = parseMiniYAML[StringTrim[temp]];\n    \n    \
  buffer = ReadString[file, \"\\n\\n\"~~StartOfLine~~\"%\"~~Repeated[\"-\", \
{16,100}]~~\"%\", TimeConstraint->timeout];\n      If[FailureQ[buffer], \
Close[file]; Return[$Failed]];\n  \n      AppendTo[list, Append[temp, \
\"Data\"->buffer]];\n  ];\n\n  If[FailureQ[temp] || FailureQ[buffer], \
Close[file]; Return[$Failed]];\n\n  keys[field] = list;\n  \n  ], {field, \
notebookHeader[\"Fields\"]}];\n    \n  \n  Close[file];\n  \n  \
Join[notebookHeader, keys]\n] \
];\n\n\nparseNotebook[\"/Users/kirill/Github/wolfram-js-frontend/prototype.md\
