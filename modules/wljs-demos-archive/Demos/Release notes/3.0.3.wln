       CoffeeLiqueur`Notebook`Cells`CellObj`$382]], 
     CoffeeLiqueur`Extensions`TOC`Private`heading[2, 
      "More tools for window management", 
      CoffeeLiqueur`Notebook`Cells`CellObj[
       CoffeeLiqueur`Notebook`Cells`CellObj`$385]], 
     CoffeeLiqueur`Extensions`TOC`Private`heading[2, "GPUArray symbols", 
      CoffeeLiqueur`Notebook`Cells`CellObj[
       CoffeeLiqueur`Notebook`Cells`CellObj`$391]], 
     CoffeeLiqueur`Extensions`TOC`Private`heading[2, 
      "Copy cells as plain text", CoffeeLiqueur`Notebook`Cells`CellObj[
       CoffeeLiqueur`Notebook`Cells`CellObj`$406]]}, 
   "TrashedCells" -> {"rasterDensityPlotAnim[x Sin[y+t], {x, -5, 5}, {y, 0, \
10}, {t, 0, 2Pi}, PlotPoints->50]", "rasterDensityPlotAnim[f_, {xs_, xmin_, \
xmax_}, {ys_, ymin_, ymax_}, {ts_, tmin_, tmax_}, OptionsPattern[]] := \n \
With[{\n   time = Unique[], buffer = Unique[], \n   cf = \
With[{c=ColorData[OptionValue[ColorFunction]]}, (List@@c[#])&], \n   pts = \
OptionValue[PlotPoints]//N,\n   dt = (tmax-tmin)/OptionValue[PlotPoints]//N\n \
 },\n  {\n   raw := Table[\n    f /. {xs -> j, ys -> i, ts -> time} // N, {i, \
ymin, \n     ymax, (ymax - ymin)/(pts - 1)}, {j, xmin, \n     xmax, (xmax - \
xmin)/(pts - 1)}]\n  },\n  \n  time = tmin;\n   \n  buffer = Map[cf, raw // \
Rescale, {2}];\n  \n  Graphics[{\n    Raster[buffer//Offload, {{xmin, xmax}, \
{ymin, ymax}}],\n    EventHandler[AnimationFrameListener[buffer//Offload], \
Function[Null,\n      buffer = Map[cf, raw // Rescale, {2}];\n      time = \
If[time >= tmax, tmin, time + dt];\n    ]]\n  }, \
Frame->True]\n]\n\nOptions[rasterDensityPlotAnim] = \
{ColorFunction->\"AvocadoColors\", PlotPoints->100};", 
     ".md\nHere is another example:", "Animate[ArrayPlot[\n  \
SeedRandom[123];\n  Table[Evaluate[Sum[Sin[RandomReal[10, 2] . {x, y} + t], \
{5}]], {x, 0, \n   5, .1}, {y, 0, 5, .1}], ImagePadding->None], {t,0,8Pi, \
0.1}, RefreshRate->60]", ".md\nMoreover it supports `Offload`, that means you \
can make it dynamic manually or automatically:"}|>, 
 "Cells" -> {<|"Data" -> ".md\n# Release notes *3.0.3*\n\n<Now/>\n", 
    "Display" -> "codemirror", "Hash" -> 
     "c9f80480-aeb6-4465-9c92-cfd2b81854f3", "Invisible" -> False, 
    "MetaOnly" -> False, "Props" -> <|"Hidden" -> True|>, 
    "PublicFields" -> {"Properties"}, "State" -> "Idle", "Type" -> "Input", 
    "UID" -> Null, "Notebook" -> "a2f235ff-2b98-4d6b-ad96-80ac07070793"|>, 
   <|"Data" -> "# Release notes *3.0.3*\n\nThu 2 Apr 2026 12:02:14", 
    "Display" -> "markdown", "Hash" -> 
     "c94948ab-108f-42be-9e12-bdac7bc69900", "Invisible" -> False, 
    "MetaOnly" -> False, "Props" -> <||>, "PublicFields" -> {"Properties"}, 
    "State" -> "Idle", "Type" -> "Output", "UID" -> Null, 
    "Notebook" -> "a2f235ff-2b98-4d6b-ad96-80ac07070793"|>, 
   <|"Data" -> ".md\n## Window Throttling\nWe fixed unintended window \
throttling on some machines, when it is not focused or hidden. This is \
crucial for a long-living applications such as monitors (lab equipment), \
where some data has to be updated continuously for hours or days. ", 
    "Display" -> "codemirror", "Hash" -> 
