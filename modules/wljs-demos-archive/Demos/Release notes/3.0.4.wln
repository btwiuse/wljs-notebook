              } else {\n                    if (Array.isArray(text)) \
text.forEach((t)=>{term.printstdout(t)}); else term.printstdout(text);\n      \
          }\n            }\n            \
server.kernel.io.fire('4c451660-9ff8-4ba0-bfb4-f2ee28941db4', true, \
