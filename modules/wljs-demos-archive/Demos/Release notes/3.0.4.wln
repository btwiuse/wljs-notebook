red \" id=\"r-#instanceId\" type=\"range\"></input></div>\n<script \
type=\"module\"> const num = document.getElementById('n-#instanceId');\n      \
  const ran = document.getElementById('r-#instanceId');\n\n        let \
harpticQ = true;\n\n        function isNumber(value) { return typeof value \
=== 'number'}\n\n        num.addEventListener('input', (event)=> {\n          \
  if (isNaN(num.value)) return;\n            ran.value = num.value;\n         \
   server.kernel.io.fire('eecc7fa5-b3fb-4e5d-9c57-249f5f761556', \
Number(num.value), 'Default');      \n        });\n\n        \
ran.addEventListener('input', (event)=> {\n            if (isNaN(ran.value)) \
return;\n            num.value = ran.value;\n            \
server.kernel.io.fire('eecc7fa5-b3fb-4e5d-9c57-249f5f761556', \
Number(ran.value), 'Default');   \n            if (harpticQ) {\n              \
  if (!window.electronAPI) {harpticQ = false; return}\n                if \
(!window.electronAPI.harptic) {harpticQ = false; return}\n                \
window.electronAPI.harptic();\n            }               \n        \
});</script>", Prolog -> 
