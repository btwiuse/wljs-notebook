Props:
  Hidden: true
Type: Input
%-------------------------------------------------------------------------%
.md
## Plot 3D
Generates a three-dimensional plot 

%-------------------------------------------------------------------------%
Display: markdown
Type: Output
%-------------------------------------------------------------------------%
## Plot 3D
Generates a three-dimensional plot 

%-------------------------------------------------------------------------%
Type: Input
%-------------------------------------------------------------------------%
Plot3D[Im[ArcSin[(x + I y)^4]], {x, -2, 2}, {y, -2, 2}, 
	Mesh -> None, 
	PlotStyle -> Directive[Yellow, Opacity[0.8]], 
	ExclusionsStyle -> {None, Red}
]

%-------------------------------------------------------------------------%
Type: Output
%-------------------------------------------------------------------------%
(*VB[*)(FrontEndRef["09594a68-bb7b-4438-b512-032498dfe995"])(*,*)(*"1:eJxTTMoPSmNkYGAoZgESHvk5KRCeEJBwK8rPK3HNS3GtSE0uLUlMykkNVgEKG1iaWpokmlnoJiWZJ+mamBgDWaaGRroGxkYmlhYpaamWlqYAdnAU9w=="*)(*]VB*)

%-------------------------------------------------------------------------%
Props:
  Hidden: true
Type: Input
%-------------------------------------------------------------------------%
.md
Another example

%-------------------------------------------------------------------------%
Display: markdown
Type: Output
%-------------------------------------------------------------------------%
Another example

%-------------------------------------------------------------------------%
Type: Input
%-------------------------------------------------------------------------%
NDSolve[{D[u[t, x], t] == D[u[t, x], x, x], u[0, x] == 0, u[t, 0] == Sin[t], u[t, 5] == 0}, u, {t, 0, 10}, {x, 0, 5}]; 

Plot3D[Evaluate[u[t, x] /. %], {t, 0, 10}, {x, 0, 5}, PlotRange -> All, ColorFunction -> "SunsetColors"]

%-------------------------------------------------------------------------%
Type: Output
%-------------------------------------------------------------------------%
(*VB[*)(FrontEndRef["b824e070-d891-416c-bb4e-fbcba932a09c"])(*,*)(*"1:eJxTTMoPSmNkYGAoZgESHvk5KRCeEJBwK8rPK3HNS3GtSE0uLUlMykkNVgEKJ1kYmaQamBvoplhYGuqaGJol6yYlmaTqpiUlJyVaGhslGlgmAwCDZxX5"*)(*]VB*)

%-------------------------------------------------------------------------%
Props:
  Hidden: true
Type: Input
%-------------------------------------------------------------------------%
.md
A __list__ version is also supported

%-------------------------------------------------------------------------%
Display: markdown
Type: Output
%-------------------------------------------------------------------------%
A __list__ version is also supporte

%-------------------------------------------------------------------------%
Props:
  Hidden: false
Type: Input
%-------------------------------------------------------------------------%
data = Table[Sin[j^2 + i], {i, 0, Pi, Pi/5}, {j, 0, Pi, Pi/5}];

ListPlot3D[data,  InterpolationOrder -> 3, 
 ColorFunction -> "SouthwestColors", BoxRatios->{1,1,0.5}]

%-------------------------------------------------------------------------%
Type: Output
%-------------------------------------------------------------------------%
(*VB[*)(FrontEndRef["ae58cf47-30ba-445b-9bb6-af955c62d9b9"])(*,*)(*"1:eJxTTMoPSmNkYGAoZgESHvk5KRCeEJBwK8rPK3HNS3GtSE0uLUlMykkNVgEKJ6aaWiSnmZjrGhskJeqamJgm6VomJZnpJqZZmpommxmlWCZZAgCN8hYP"*)(*]VB*)

%-------------------------------------------------------------------------%
Type: Input
%-------------------------------------------------------------------------%
Plot3D[Sin[Sqrt[x^2 + y^2]], {x, -6, 6}, {y, -6, 6}, 
 PlotRange -> All, 
 Mesh -> None, 
 ColorFunction -> "Rainbow"]

%-------------------------------------------------------------------------%
Type: Output
%-------------------------------------------------------------------------%
(*VB[*)(FrontEndRef["cd437ffa-2116-4854-bee0-a6cdd27873a4"])(*,*)(*"1:eJxTTMoPSmNkYGAoZgESHvk5KRCeEJBwK8rPK3HNS3GtSE0uLUlMykkNVgEKJ6eYGJunpSXqGhkamumaWJia6CalphroJpolp6QYmVuYGyeaAACJ+xXS"*)(*]VB*)

