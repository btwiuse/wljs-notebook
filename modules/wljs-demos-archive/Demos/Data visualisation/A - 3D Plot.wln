%-------------------------------------------------------------------------%
## Vector Plot 3D
Visualize vector field in 3D

%-------------------------------------------------------------------------%
Props:
  Hidden: false
Type: Input
%-------------------------------------------------------------------------%
VectorPlot3D[{x, y, z}, {x, -1, 1}, {y, -1, 1}, {z, -1, 1}]

%-------------------------------------------------------------------------%
Type: Output
%-------------------------------------------------------------------------%
(*VB[*)(FrontEndRef["00b61c6f-4e38-49cd-869c-1c2132abee82"])(*,*)(*"1:eJxTTMoPSmNkYGAoZgESHvk5KRCeEJBwK8rPK3HNS3GtSE0uLUlMykkNVgEKGxgkmRkmm6XpmqQaW+iaWCan6FqYWSbrGiYbGRobJSalploYAQCA2RWg"*)(*]VB*)

