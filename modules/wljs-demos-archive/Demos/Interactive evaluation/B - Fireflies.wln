#1](*|*),(*|*)True(*|*)}}](*|*)(*1:eJxTTMoPSmNiYGAo5gUSYZmp5S6pyflFiSX5RcGcQJ\
GAzNTk1PLM4tRMkCIAD2QL0A==*)(*]TB*)],\n  PlotLabel->\"Cells in a flashing \
