 "Cells" -> {<|"Data" -> ".md\n# Animated Density Plot\nHere is our basic \
implementation of a raster density plot function with an extra parameter used \
for animation:", "Display" -> "codemirror", 
    "Hash" -> "7d1d5664-370e-437a-9829-e046343447ed", "Invisible" -> False, 
    "MetaOnly" -> False, "Props" -> <|"Hidden" -> True|>, 
    "PublicFields" -> {"Properties"}, "State" -> "Idle", "Type" -> "Input", 
    "UID" -> Null, "Notebook" -> "e239ee5b-16c3-4450-84a5-9b1796ceac9c"|>, 
   <|"Data" -> "# Animated Density Plot\nHere is our basic implementation of \
a raster density plot function with an extra parameter used for animation:", 
    "Display" -> "markdown", "Hash" -> 
     "eb5ecb87-18bd-47e4-9abe-aa6b8ddbe462", "Invisible" -> False, 
    "MetaOnly" -> False, "Props" -> <||>, "PublicFields" -> {"Properties"}, 
    "State" -> "Idle", "Type" -> "Output", "UID" -> Null, 
    "Notebook" -> "e239ee5b-16c3-4450-84a5-9b1796ceac9c"|>, 
   <|"Data" -> "rasterDensityPlotAnim[f_, {xs_, xmin_, xmax_}, {ys_, ymin_, \
ymax_}, {ts_, tmin_, tmax_}, OptionsPattern[]] := \n With[{\n   time = \
Unique[], buffer = Unique[], \n   cf = \
With[{c=ColorData[OptionValue[ColorFunction]]}, (List@@c[#])&], \n   pts = \
OptionValue[PlotPoints]//N,\n   dt = (tmax-tmin)/OptionValue[PlotPoints]//N\n \
 },\n  {\n   (*BB[*)(* call to resample our function on a grid \
*)(*,*)(*\"1:eJxTTMoPSmNhYGAo5gcSAUX5ZZkpqSn+BSWZ+XnFaYwgCS4g4Zyfm5uaV+KUXxEM\
Uqxsbm6exgSSBPGCSnNSg9mAjOCSosy8dLBYSFFpKpoKkDkeqYkpEFXBILO1sCgJSczMQVYCAOFrJ\
EU=\"*)(*]BB*)\n   raw := Table[\n    f /. {xs -> j, ys -> i, ts -> time} // \
N, {i, ymin, \n     ymax, (ymax - ymin)/(pts - 1)}, {j, xmin, \n     xmax, \
(xmax - xmin)/(pts - 1)}]\n  },\n  \n  time = tmin;\n\n  (*BB[*)(* rescale to \
[0,1] and colorize \
*)(*,*)(*\"1:eJxTTMoPSmNhYGAo5gcSAUX5ZZkpqSn+BSWZ+XnFaYwgCS4g4Zyfm5uaV+KUXxEM\
Uqxsbm6exgSSBPGCSnNSg9mAjOCSosy8dLBYSFFpKpoKkDkeqYkpEFXBILO1sCgJSczMQVYCAOFrJ\
EU=\"*)(*]BB*)\n  buffer = Map[cf, raw // Rescale, {2}];\n  \n  Graphics[{\n  \
  Raster[buffer//Offload, {{xmin, xmax}, {ymin, ymax}}],\n\n    (*BB[*)(* \
animate infinitely \
*)(*,*)(*\"1:eJxTTMoPSmNhYGAo5gcSAUX5ZZkpqSn+BSWZ+XnFaYwgCS4g4Zyfm5uaV+KUXxEM\
Uqxsbm6exgSSBPGCSnNSg9mAjOCSosy8dLBYSFFpKpoKkDkeqYkpEFXBILO1sCgJSczMQVYCAOFrJ\
EU=\"*)(*]BB*)\n    EventHandler[AnimationFrameListener[buffer//Offload], \
Function[Null,\n      buffer = Map[cf, raw // Rescale, {2}];\n      time = \
If[time >= tmax, tmin, time + dt];\n    ]]\n  }, \
Frame->True]\n]\n\nOptions[rasterDensityPlotAnim] = \
{ColorFunction->\"AvocadoColors\", PlotPoints->100};", 
    "Display" -> "codemirror", "Hash" -> 
     "4b7d308b-0be4-4c0a-a964-336799c4d7a7", "Invisible" -> False, 
    "MetaOnly" -> False, "Props" -> <||>, "PublicFields" -> {"Properties"}, 
