    "Notebook" -> "9d01a796-6ef9-4d6d-bafa-4fb630c0bb77"|>, 
   <|"Data" -> ".slide\n\n<!-- .slide: class=\"slide-standard slide-dark\" \
data-background-color=\"black\" -->\n\n<MakeTitle>Our Tool: Time-Resolved THz \
<span style=\"letter-spacing: \
-3px;\">Magnetospectroscopy</span></MakeTitle>\n\n<Row>\n\n  \n<div>\n  \
<WidgetAnimation Run={True}/>\n</div>\n\n\n<div \
class=\"dark-content\">\n\n<DomainPlots Type={\"Time\"}/>\n\n<div \
style=\"width:500px; color:black; padding-top:1rem; padding-bottom:1rem; \
text-align:center\">$\\downarrow \\quad \
\\mathrm{Fourier,}~\\small\\text{Out/In} \\quad \
\\downarrow$</div>\n\n<DomainPlots \
Type={\"Frequency\"}/>\n\n</div>\n\n</Row>\n\n<Footer/>", 
