   <|"Data" -> "fPulse = Compile[{{t, _Real}, {x, _Real}},  \
(*FB[*)((1)(*,*)/(*,*)(200.0))(*]FB*) Sum[Exp[- (8-w)^2 0.02] Sin[w t - 10.0 \
x w], {w,0,20.0,0.5}]];\n\n\n\ngrange = Table[\\[Tau], {\\[Tau], \
-5,0,0.1}];\ngenPulse[t_, offset_, x_] := Map[4 responceFunction[-#] fPulse[t \
+ #, x + offset ]&, grange] // Total\nresponceFunction[t_] := \
(*FB[*)((((*SpB[*)Power[E(*|*),(*|*)-(*FB[*)((5)(*,*)/(*,*)(40))(*]FB*) \
((*SpB[*)Power[t(*|*),(*|*)2](*]SpB*))](*]SpB*)) Sin[20 \
t])(*,*)/(*,*)((*SqB[*)Sqrt[2](*]SqB*)))(*]FB*) \n\n\nmirrorTop = \
-0.81;\ndelta = 0.02;\ntscale = 2.0;\nySpeed = 0.1;\nxSpeed = \
0.2;\n\nautoMode = False;\n\nsampledPoints = <||>;\nsampledPointsP = \
{{0,0}};\n\npaths := (\n  path1Line = With[{t = tscale AbsoluteTime[]},\n    \
Table[{x, fPulse[t, 1.5 - x]}, {x,0.75, 1.5, delta}]\n  ];\n\n  path11Line = \
With[{t = tscale AbsoluteTime[]},\n    Table[{x, 3 fPulse[t, 1.5 - x]}, {x,0, \
0.75, delta}]\n  ];\n\n  path2Line = With[{t = tscale AbsoluteTime[]},\n    \
Table[{fPulse[t, 0.5 - x ySpeed] + 1, x}, {x, -1, 0, delta}]\n  ];\n\n  \
path3Line = With[{t = tscale AbsoluteTime[]},\n    Table[{x, fPulse[t, 0.5 + \
1 ySpeed + (1 - x) xSpeed] - 1}, {x, 0.5, 1, delta}]\n  ];\n\n  path4Line = \
With[{t = tscale AbsoluteTime[]},\n    Table[{fPulse[t, 0.5 + 1 ySpeed + 0.5 \
xSpeed + (x + 1)] + 0.5, x}, {x, -1, mirrorTop, delta}]\n  ];\n\n  path5Line \
= With[{t = tscale AbsoluteTime[]},\n    Table[{x, fPulse[t, 0.5 + 1 ySpeed + \
0.5 xSpeed + (mirrorTop + 1) + xSpeed (0.5 - x)] + mirrorTop}, {x, -0.5, 0.5, \
delta}]\n  ];\n\n  path6Line = With[{t = tscale AbsoluteTime[]},\n    \
Table[{fPulse[t, 0.5 + 1 ySpeed + 0.5 xSpeed + (mirrorTop + 1) + xSpeed 1 + \
(*FB[*)((((0) - (1 + mirrorTop)))(*,*)/(*,*)((mirrorTop + 1)))(*]FB*)(x+1) + \
(1 + mirrorTop)] - 0.5, x}, {x, -1, mirrorTop, delta}]\n  ];\n\n  path7Line = \
With[{t = tscale AbsoluteTime[]},\n    Table[{x, fPulse[t, 0.5 + 1 ySpeed + \
0.5 xSpeed + (mirrorTop + 1) + xSpeed 1 + (1 + mirrorTop) - (x + 0.5) xSpeed] \
- 1}, {x, -1,-0.5, delta}]\n  ];\n\n  path8Line = With[{t = tscale \
AbsoluteTime[]},\n    Table[{fPulse[t, 0.5 + 1 ySpeed + 0.5 xSpeed + \
(mirrorTop + 1) + xSpeed 1 + (1 + mirrorTop) + 0.5 xSpeed + ySpeed (x + 1)] - \
1, x}, {x, -1, 0, delta}]\n  ];\n\n  path9Line = With[{t = tscale \
AbsoluteTime[]},\n    Table[{x, fPulse[t, 0.5 + 1 ySpeed + 0.5 xSpeed + \
(mirrorTop + 1) + xSpeed 1 + (1 + mirrorTop) + 0.5 xSpeed + ySpeed 1 + (x + \
1)]}, {x, -1, -0.75, delta}]\n  ];\n\n  path10Line = With[{t = tscale \
AbsoluteTime[]},\n    Table[{x, genPulse[t, 1, -x + 0.5]}, {x, -0.75, -0.15, \
delta}]\n  ];\n\n  persOffset = If[autoMode, Range[-0.1,0.1,0.01], \
Range[-0.02,0.02,0.01]];\n\n  \n);\n\npaths;\n\ntrigger2 = False;\n\ntdsBlock \
= True;\n\ntdsEvent = CreateUUID[];\n\nEventHandler[tdsEvent, \
Function[Null,\n  If[tdsBlock, Return[]];\n  paths;\n  trigger2 = \
True;\n]];\n\n\ngenerateGraphics := Graphics[{\n\n{\n\n    \
Inset[Graphics3D[{Gray,Cuboid[{-1,0,-1}, {1,0.4,1}], PointLight[Red, With[{s \
= Abs[path11Line[[1]][[2]]]}, {-1.5 s,-1.5 s,0.1}] // Offload]}, \
ImageSize->200], {0,0}, Center]\n  },AbsoluteThickness[2],\n  \
ColorData[97][1], \n  Line[path1Line // Offload], \n  Line[path2Line // \
Offload], \n  Line[path3Line // Offload], \n  Line[path4Line // Offload], \n  \
Line[path5Line // Offload], \n  Line[path6Line // Offload], \n  \
Line[path7Line // Offload], \n  Line[path8Line // Offload], \n  \
Line[path9Line // Offload],\n   ColorData[97][4],\n  Line[path10Line // \
Offload],\n  Line[path11Line // Offload],\n\n  {\n    Black, \
AbsoluteThickness[3],\n    Line[{{-1,-1}+{-0.05,0.05}, \
{-1,-1}+{0.05,-0.05}}],\n    Line[{{1,-1}+{-0.05,-0.05}, \
{1,-1}+{0.05,0.05}}],\n    Line[{{1-0.5,-1}+{-0.05,0.05}, \
{1-0.5,-1}+{0.05,-0.05}}],\n    Line[{{1-0.5-1,-1}+{-0.05,-0.05}, \
{1-0.5-1,-1}+{0.05,0.05}}],\n    Line[With[{y = mirrorTop}, \
{{-0.5,y}+{-0.05,-0.05}, {-0.5,y}+{0.05,0.05}}] // Offload],\n    \
Line[With[{y = mirrorTop}, {{1-0.5,y}+{-0.05,0.05}, {1-0.5,y}+{0.05,-0.05}}] \
// Offload],\n    Line[{{-1,0}+{-0.05,-0.05}, {-1,0}+{0.05,0.05}}]\n    \n  \
},\n\n  {\n    ColorData[97][12],\n    \
Translate[Scale[FilledCurve[{BezierCurve[0.1{{0,1}, {-1,0}, {0,-1}}]}], 2], \
{-0.75,0}],\n    Translate[Scale[FilledCurve[{BezierCurve[0.1{{0,1}, {1,0}, \
{0,-1}}]}], 2], {0.75,0}]\n  },\n\n  {\n    Cyan, Opacity[0.7], \
Translate[Scale[Polygon[0.7 \
