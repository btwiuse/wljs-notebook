   <|"Data" -> ".wlx\n\nClearAll[WidgetTDS];\nWidgetTDS[_] := \
With[{GraphicsPane = generateGraphics, slideEvent = CreateUUID[]},\n\n \
EventHandler[slideEvent, {\n  \"Slide\" -> Function[Null,\n    Print[\"Unlock \
TDS animation\"];\n    tdsBlock = False;\n    tscale = 3.0;\n    delta = \
0.02;\n    autoMode = False;\n    mirrorTop = -0.81;\n    EventFire[tdsEvent, \
True];\n    \n  ],\n\n  \"Left\" -> Function[Null,\n    tscale = 3.0;\n    \
delta = 0.02;\n    mirrorTop = -0.81;\n    autoMode = False;\n    \
Print[\"Lock TDS animation\"];\n    tdsBlock = True;\n  ],\n\n  \"Destroy\" \
-> Function[Null,\n    tscale = 3.0;\n    mirrorTop = -0.81;\n    delta = \
0.02;\n    autoMode = False;\n    Print[\"Lock TDS animation\"];\n    \
tdsBlock = True;\n  ]\n }];\n\n <div>\n   <GraphicsPane/>\n   \
<SlideEventListener Id={slideEvent}/>\n </div>\n]", 
