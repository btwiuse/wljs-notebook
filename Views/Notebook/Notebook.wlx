CellsContainer  = ImportComponent["Skeleton/CellsContainer.wlx"];
TopBar          = ImportComponent["Skeleton/TopBar.wlx"];

{CellGenerator, CellGeneratorScript}   = ImportComponent["CellGenerator.wlx"];

{ControlsL, ControlsR, ControlsScript}            = ImportComponent["Skeleton/Controls.wlx"];
{Hr, HrScript}                        = ImportComponent["Skeleton/Hr.wlx"];
{EvaluationBar, EvaluationBarScript}  = ImportComponent["Skeleton/EvaluationBar.wlx"];

{CellDropdown, DropdownScript} = ImportComponent["Skeleton/Dropdown.wlx"];

KernelIndicator = ImportComponent["Skeleton/KernelIndicator.wlx"];

ElectronBinds  = ImportComponent["Skeleton/ElectronBinds.wlx"];

Global`UINotebook (*`*);

ApplySync[f_, w_, {first_, rest___}, final_] := f[w@@first, Function[Null, Echo["Async >> Next"]; ApplySync[f,w, {rest}, final]]]
ApplySync[f_, w_, {}, final_] := final[];

trashCell[notebook_, cell_] := Module[{},
    If[!cell`InputCellQ[cell], Return[Null, Module]];
    If[TrueQ[cell["Props"]["Locked"]], Return[Null, Module]];
    If[TrueQ[cell["Invisible"]], Return[Null, Module]];
    If[!TrueQ[StringLength[StringTrim[cell["Data"]]] > 0 ], Return[Null, Module]];
    If[!ListQ[notebook["TrashedCells"]], notebook["TrashedCells"] = {}];
    notebook["TrashedCells"] = Take[Prepend[notebook["TrashedCells"], cell["Data"]], UpTo[5]];
];

untrashCell[notebook_, log_, modals_] := Module[{},
    If[!ListQ[notebook["TrashedCells"]] || Length[notebook["TrashedCells"]] == 0,
        EventFire[log, "Warning", "No trashed input cells found"];
        Return[Null, Module];
    ]; With[{promise = Promise[]},

        Then[promise, Function[result, 
          Echo[StringJoin["Picked cell >> ", ToString[result]]];
          Switch[result,
            _Integer, 
                cell`CellObj[
                    "Notebook" -> notebook,
                    "Data" -> notebook["TrashedCells"][[result]],
                    "Display" -> "codemirror",
                    "Type" -> "Input",
                    "After" -> If[MatchQ[notebook["FocusedCell"], _cell`CellObj], notebook["FocusedCell"], notebook["Cells"][[-1]]]
                ];
                notebook["TrashedCells"] = ReplacePart[notebook["TrashedCells"], result -> Nothing];
            ,
            
            _,
                Print["Cancelled"]; 
        ] ] ];

        EventFire[modals, "SelectBox", <|
                "Promise"->promise, "message"->"Choose one to restore", 
                "title"->"Trashed cells", "list"->Map[Function[k, 
                    StringReplace[StringTake[k, UpTo[10]], "\n"->" "] 
                ], notebook["TrashedCells"]]
        |>]; 
] ];

addAfterHelper[notebook_, uid_] := With[{},
    (*/* request from the client with event provided */*)

    With[{o = cell`HashMap[uid] (*`*)},
        cell`CellObj["Notebook"->notebook, "Data"->"", "After"-> o];   
    ]
]

addAfterHelper[notebook_, {uid_, data_}] := With[{},
    (*/* request from the client with event provided */*)

    With[{o = cell`HashMap[uid] (*`*)},
        cell`CellObj["Notebook"->notebook, "Data"->data, "After"-> o];   
    ]
]

addBeforeHelper[notebook_, uid_] := With[{},
    (*/* request from the client with event provided */*)

    With[{o = cell`HashMap[uid] (*`*)},
        cell`CellObj["Notebook"->notebook, "Data"->"", "Before"-> o];   
    ]
]

addBeforeHelper[notebook_, {uid_, data_}] := With[{},
    (*/* request from the client with event provided */*)

    With[{o = cell`HashMap[uid] (*`*)},
        cell`CellObj["Notebook"->notebook, "Data"->data, "Before"-> o];   
    ]
]

addListeners[notebook_nb`NotebookObj, secret_String, client_, parameters_, extensions__] := Module[{clonedEvent = EventClone[notebook]},
    (* /* don't clone Notebook event, must be one ! */ *)
    EventHandler[clonedEvent, {
        "New Cell" -> Function[cell,
            With[{list = #["Hash"] &/@ (cell["Notebook","Cells"])},
                WebUISubmit[UINotebook["NewCell", CellGenerator[cell, client, parameters, extensions], cell`Serialize[cell] , list, secret], client]
            ];
        ],

        "Remove Cell" -> Function[cell,
            With[{},
                WebUISubmit[UINotebook["RemoveCell", cell["Hash"], secret], client]
            ];            
        ]
    }];

    With[{socket = EventClone[client]},
        EventHandler[socket, {"Closed" -> Function[Null,
            EventRemove[socket];
            EventRemove[clonedEvent];
            Echo["addListeners >> destroed listeners"];        
        ]}];
    ];
];

restoreCells[notebook_nb`NotebookObj, secret_String, client_, parameters_, extensions__] := Module[{},
    Map[
        Function[cell,
            With[{list = #["Hash"] &/@ (cell["Notebook","Cells"])},
                WebUISubmit[UINotebook["NewCell", CellGenerator[cell, client, parameters, extensions], cell`Serialize[cell], list, secret, "IgnoreList" -> True, "FocusFirst" -> True] (*`*), client];
            ]
        ]   
    ,    
        notebook["Cells"]
    ]
];

checkWSLink[notebook_, client_, event_String, log_String, p_:Null] := With[{
    promise = If[p === Null, Promise[], p]
},
    (*/* check if connected already */*)
    Echo["checkWSLink >> "];

    If[notebook["WebSocketQ"] === True, 
        Echo["checkWSLink >> Already connected"];
        EventFire[promise, Resolve, True];
        Return[];
    ];

    (*/* check if has working kernel */*)
    If[notebook["Evaluator"]["Kernel"]["Dead"] === False,
        (*/* check if it was initialized succesfully */*)

        If[notebook["Evaluator"]["Kernel"]["State"] === "Initialized",
            With[{
                notebookEvent = EventClone[notebook]
            },
                Echo["checkWSLink >> Asking to connect"];

                EventFire[log, "WebSocket:Kernel:RequestConnection", notebook];

                WebUISubmit[UINotebook["WSConnect", notebook["Evaluator"]["Kernel"]["WebSocket"], event , "PrefixMode"->$Env["ws2prefix"]], client];

                With[{},
                    EventHandler[notebookEvent, {
                        "AfterWebSocketConnected" -> Function[Null,
                            EventRemove[notebookEvent];
                            Echo["Resolved! Starting to evaluate!"];
                            EventFire[log, "WebSocket:Kernel:Connected", notebook];
                            EventFire[promise, Resolve, True];
                        ],

                        "WebSocketLost" -> Function[Null,
                            EventFire[log, "WebSocket:Kernel:Lost", notebook];
                            EventRemove[notebookEvent];
                        ]
                    }]
                ];


                (*/* subscribe to event when Kernel dies */*)
                With[{cloned = EventClone[notebook["Evaluator"]["Kernel"]]},
                    EventHandler[cloned, {
                        "Exit" -> Function[Null,
                            EventRemove[cloned];
                            EventRemove[notebookEvent];
                            EventFire[log, "WebSocket:Kernel:Lost", notebook];
                            Echo["checkWSLink >> Kernel connection lost >> removing..."];
                            notebook["WebSocketQ"] = False;
                        ]
                    }];

                    (*/* destructor if connection lost */*)
                    With[{socket = EventClone[client]},
                        EventHandler[socket, {
                            "Closed" -> Function[Null,
                                EventRemove[socket];
                                EventRemove[cloned];
                                EventRemove[notebookEvent];
    
                                Echo["checkWSLink >> Socket connection lost >> removing handlers"];
                                EventRemove[promise // First];
                            ]
                        }];
                    ];
                ];
            ];
        ,
            (*/* subscribe when ready */*)
            Echo["checkWSLink >> subscribing when ready"];

            With[{clone = EventClone[notebook["Evaluator"]["Kernel"]]},
                EventHandler[clone, {"State" -> Function[Null,
                    If[state === "Initialized",
                        EventRemove[clone];
                        checkWSLink[notebook, client, event, log, promise];
                    ];
                ]}]
            ];

        ]
    ,
        (*/* subscribe when it will be attached */*)

        Echo["checkWSLink >> no Kernel available... >> subscribing"];

        With[{cloned = EventClone[notebook]},
            EventHandler[cloned, {"AquairedKernel" -> Function[Null,
                EventRemove[cloned];
                checkWSLink[notebook, client, event, log, promise];
            ]}]; 
            
            With[{socket = EventClone[client]},
                EventHandler[socket, {"Closed" -> Function[Null,
                    EventRemove[socket];
                    Echo["checkWSLink >> destroy"];
                    EventRemove[cloned];
                    EventRemove[promise // First];
                ]}];
            ];
        ];    
    ];

    promise
];

requestKernel[notebook_, kernels_, modals_, client_, Success_] := With[{},
    Print["requesting modal...."];
    With[{promise = Promise[]},
        Then[promise, Function[result, 
          Echo[StringJoin["Picked kernel >> ", ToString[result]]];
          Switch[result,
            _Integer, 
             With[{k = ReleaseHold[kernels][[result]]},
                
                If[TrueQ[k["ContainerReadyQ"]],
                    notebook["Evaluator"] = k["Container"];
                    EventFire[notebook, "AquairedKernel", True];
                    Success[Null];
                ,
                    WebUISubmit[Alert["Initialization is not complete"], client];
                ];
             ];
            ,
            
            _,
                Print["Cancelled"]; 
        ] ] ];

        If[Length[ReleaseHold[kernels]] == 1,
            Echo["Autoselected 1"];
            EventFire[promise, Resolve, 1];    
        ,
            Print["fire!"];
            EventFire[modals, "SelectBox", <|
                "Promise"->promise, "message"->"Choose an evaluation kernel", 
                "title"->"Kernel list", "list"->Map[Function[k, k["Name"]], ReleaseHold[kernels]]
            |>];        
        ];
    ];
];

projectCellOrUpdate[cell_, notebook_, secret_String, log_String, kernels_, cli_, modals_, parameters_, extensions__] := With[{
    client = If[MatchQ[cli, _Symbol], notebook["Socket"], cli]
},

    
    With[{project = Function[Null,
        With[{found = SelectFirst[Values[win`HashMap], Function[window, TrueQ[window["Single"] ] && window["Ref"] === cell["Hash"] && window["Opened"] === True ] ] },
            If[MissingQ[found],
                With[{win = win`WindowObj["Single"->True, "Notebook" -> cell["Notebook"], "Data" -> cell["Data"], "Ref"     -> cell["Hash"] ]},
                    Echo["project >> sending global event"];
                    EventFire[notebook, "OnWindowCreate", <|"Window"->win, "Client"->client|>];
                    WebUILocation[StringJoin["/window?id=", win["Hash"] ], client, "Target"->_];
                ] 
            ,
                found["Data"] = cell["Data"];
                EventFire[found, "Reevaluate", True];
            ];
        ] ]
    },

        (*/* Check kernel and evaluator */*)
        If[notebook["Evaluator"]["Kernel"]["State"] === "Initialized",
            If[Length[ReleaseHold @ kernels] == 0, WebUISubmit[Alert["No Kernels are available"], client]; Return[] ];

            (*/* Kernel looks conected and etc */*)
            Print["ok!"];

            (*/* the last check */*)
            With[{},
                If[cell["State"] != "Idle",
                    WebUISubmit[Alert["Cell is still under evaluation"], client];
                ,
                    Then[checkWSLink[notebook, client, secret, log], 
                        project
                    ];
                ];
            ];
        ,
            If[Length[ReleaseHold @ kernels] == 0, WebUISubmit[Alert["No Kernels are available"], client]; Return[] ];

            requestKernel[notebook, kernels, modals, client, Function[Null,
                With[{},
                            If[cell["State"] != "Idle",
                                WebUISubmit[Alert["Cell is still under evaluation"], client];
                            ,
                                Echo["Success!"];
                                Then[checkWSLink[notebook, client, secret, log], project];
                            ]
                ];
            ] ];
        ];
    ];
] 

projectCell[cell_, notebook_, secret_String, log_String, kernels_, cli_, modals_, parameters_, extensions__] := With[{
    client = If[MatchQ[cli, _Symbol], notebook["Socket"], cli]
},

    
    With[{project = Function[Null,
        With[{win = win`WindowObj["Notebook" -> cell["Notebook"], "Data" -> cell["Data"], "Ref" -> cell["Hash"] ]},
            Echo["project >> sending global event"];
            EventFire[notebook, "OnWindowCreate", <|"Window"->win, "Client"->client|>];
            WebUILocation[StringJoin["/window?id=", win["Hash"] ], client, "Target"->_];
        ] ]
    },

        (*/* Check kernel and evaluator */*)
        If[notebook["Evaluator"]["Kernel"]["State"] === "Initialized",
            If[Length[ReleaseHold @ kernels] == 0, WebUISubmit[Alert["No Kernels are available"], client]; Return[] ];

            (*/* Kernel looks conected and etc */*)
            Print["ok!"];

            (*/* the last check */*)
            With[{},
                If[cell["State"] != "Idle",
                    WebUISubmit[Alert["Cell is still under evaluation"], client];
                ,
                    Then[checkWSLink[notebook, client, secret, log], 
                        project
                    ];
                ];
            ];
        ,
            If[Length[ReleaseHold @ kernels] == 0, WebUISubmit[Alert["No Kernels are available"], client]; Return[] ];

            requestKernel[notebook, kernels, modals, client, Function[Null,
                With[{},
                            If[cell["State"] != "Idle",
                                WebUISubmit[Alert["Cell is still under evaluation"], client];
                            ,
                                Echo["Success!"];
                                Then[checkWSLink[notebook, client, secret, log], project];
                            ]
                ];
            ] ];
        ];
    ];
] 

projectCellData[cell_, evaluatedQ_, data_, display_, uid_,  imageSize_, offscreen_, notebook_, secret_String, log_String, kernels_, cli_, modals_, parameters_, extensions__] := With[{
    client = If[MatchQ[cli, _Symbol], notebook["Socket"], cli]
},


    
    With[{win = win`WindowObj["Notebook" -> notebook, "EvaluatedQ" -> evaluatedQ, "Display"->display, "Hash"->uid, "Data" -> data, "Ref" -> cell["Hash"] ]},
            Echo["project >> sending global event"];
            EventFire[notebook, "OnWindowCreate", <|"Window"->win, "Client"->client|>];

            If[offscreen,
                WebUILocation[StringJoin["/window?id=", win["Hash"] ], client, "Target"->_, "Features"->"width=1,height=1"];
            ,
                If[imageSize === Automatic,
                    WebUILocation[StringJoin["/window?id=", win["Hash"] ], client, "Target"->_];
                ,
                    With[{features = If[ListQ[imageSize], StringTemplate["width=``,height=``"][imageSize[[1]], imageSize[[2]] ], StringTemplate["width=``,height=``"][imageSize, 0.76 imageSize ] ]},
                        WebUILocation[StringJoin["/window?id=", win["Hash"] ], client, "Target"->_, "Features" -> features];
                    ]
                ];            
            ];
    ];
] 

checkEvaluationCells[currentCell_, notebook_, secret_, log_, kernels_, client_, modals_, parameters_, extensions__] := Module[{

},
    If[TrueQ[notebook["CellsInitialized"]], Return[Null, Module]];
    notebook["CellsInitialized"] = True;
    Echo[">> Found initialization cells!"];

    With[{
        rpromise = Promise[],
        promise = Promise[]
    },
        Then[rpromise, Function[result,
            If[TrueQ[result] || result["response"] === 0,
                ApplySync[Then, evaluateCell, {
                        #, notebook, secret, log, kernels, client, modals, parameters, extensions
                    } &/@ Select[notebook["Cells"], TrueQ[#["Props"]["InitGroup"]]&], Function[Null,
                    
                    Echo[">> Found initialization cells >> done"];
                    If[TrueQ[currentCell["Props"]["InitGroup"]], 
                        EventFire[promise, Reject, True];
                    ,
                        EventFire[promise, Resolve, True];
                    ];
                ]];            
            ,
                EventFire[promise, Resolve, True];
            ];
        ]];

        EventFire[modals, "MessageBox", <|
            "title"->"Initialization cells",
            "message"->"Evaluate initialization cells?",
            "type"->"question",
            "buttons"->{"Evaluate", "Cancel"},
            "Promise"->rpromise
        |>];

        promise
    ]
]

evaluateCell[cell_, notebook_, secret_String, log_String, kernels_, cli_, modals_, parameters_, extensions__] := With[{promise = Promise[], client = If[MatchQ[cli, _Symbol], notebook["Socket"], cli]}, Module[{},
    

    With[{},
        If[cell["Type"] == "Output",
            Echo["Morphing..."];
            cell["Type"] = "Input";

            With[{template = CellGenerator[cell, client, parameters, extensions]},
                WebUISubmit[UINotebook["Morph", cell["Hash"], template, cell`Serialize[cell, "MetaOnly"->True] (*`*)], client];
            ];
        ];
    ];

    (* /*if this is an evaluation  cell, then switch the flag on*/ *)
    If[notebook["CellsInitialized"] =!= True,
        If[Length[Select[notebook["Cells"], TrueQ[#["Props"]["InitGroup"]]&]] == 0,
            notebook["CellsInitialized"] = True;
        ];
    ];

    Print["Evaluate"];

    (*/* Check kernel and evaluator */*)
    If[notebook["Evaluator"]["Kernel"]["State"] === "Initialized",
        If[Length[ReleaseHold @ kernels] == 0, WebUISubmit[Alert["No Kernels are available"], client]; Return[] ];

        (*/* Kernel looks conected and etc */*)
        Print["ok!"];

        (*/* the last check */*)
        With[{},
            If[cell["State"] != "Idle",
                WebUISubmit[Alert["Cell is still under evaluation"], client];
            ,
                Then[checkWSLink[notebook, client, secret, log], Function[Null,
                    Then[checkEvaluationCells[cell, notebook, secret, log, kernels, client, modals, parameters, extensions], Function[Null,
                        cell // cell`EvaluateCellObj;
                        EventFire[promise, Resolve, True];
                    ],
                    Function[Null,
                        Echo["Skipping the given cell"];
                        EventFire[promise, Resolve, True];
                    ]];
                ]];
            ];
        ];
    ,
        If[Length[ReleaseHold @ kernels] == 0, Print["No kernels..."]; WebUISubmit[Alert["No Kernels are available"], client]; Return[] ];
        
        requestKernel[notebook, kernels, modals, client, Function[Null,
            With[{},
                        If[cell["State"] != "Idle",
                            WebUISubmit[Alert["Cell is still under evaluation"], client];
                        ,
                            Echo["Success!"];
                            Then[checkWSLink[notebook, client, secret, log], Function[Null,
                                Then[checkEvaluationCells[cell, notebook, secret, log, kernels, client, modals, parameters, extensions], Function[Null,
                                    cell // cell`EvaluateCellObj;
                                    EventFire[promise, Resolve, True];
                                ],
                                Function[Null,
                                    Echo["Skipping the given cell"];
                                    EventFire[promise, Resolve, True];
                                ]
                                ];
                            ]];
                        ]
            ];
        ]];
    ];

    promise
] ];


evaluateCellFull[cell_, notebook_, secret_String, log_String, kernels_, cli_, modals_, parameters_, extensions__] := With[{p = Promise[]},
    Then[evaluateCell[cell, notebook, secret, log, kernels, cli, modals, parameters, extensions], Function[Null,
        GenericKernel`Init[notebook["Evaluator"]["Kernel"],  (  
            EventFire[Internal`Kernel`Stdout[ p[[1]] ], Resolve, True];
        )];
    ]];
    p
];

Script[OptionsPattern[]] := With[{
    ExtensionTemplateInjection = OptionValue["ExtensionTemplateInjection"],
    InputSaveDelay = Lookup[OptionValue["Parameters"], "InputSaveDelay", 180]
},
    <div>
        <script type="module">
            CellWrapper.inputSaveDelay = <InputSaveDelay/>;

            core.UINotebook = async (args, env) => {
                const type = await interpretate(args[0], env);
                core.UINotebook[type](args.slice(1), env);
            }

            core.UINotebook.CreateServer = async (args, env) => {
                server.kernel = new Server('Evaluation Kernel');
                console.warn("server.kernel :: created, waiting for initialization...");
            }

            core.UINotebook.WSConnect = async (args, env) => {
                
                const options = await core._getRules(args, env);
                const port = await interpretate(args[0], env);
                const ev = await interpretate(args[1], env);

                console.warn('Trying to connect on port ' + port + ' to evaluation kernel');
                if (server.kernel.connected) {
                    console.warn('A request to connect was rejected, since socket is still alive');
                    return;
                }

                server.kernel.connected = true;
                let socket;
                if (options.PrefixMode) {
                    socket = new WebSocket((window.location.protocol == "https:" ? "wss://" : "ws://")+window.location.hostname+':'+window.location.port+'/'+options.PrefixMode);
                } else {
                    socket = new WebSocket((window.location.protocol == "https:" ? "wss://" : "ws://")+window.location.hostname+':'+port);
                }

                socket.binaryType = "arraybuffer";
                socket.onmessage = interpretate.handleMessage;

                socket.onopen = function(e) {
                  console.warn("[open] Evaluation Kernel");
                  server.kernel.init({socket: socket});
                  server.emitt(ev, 'True', 'WebSocketConnected');
                }; 

                

                socket.onclose = function(event) {
                  console.log(event);
                  console.warn('Connection lost to a Evaluation Kernel');
                  //server.kernel = undefined;
                  server.kernel.connected = false;
                  server.kernel.dispose();

                  server.emitt(ev, 'True', 'WebSocketLost');
                }; 
            }

            core.UINotebook.Morph = async (args, env) => {
                const uid = await interpretate(args[0], env);
                const template = await interpretate(args[1], env);
                const props = await interpretate(args[2], env);

                CellWrapper.morph(uid, template, props);
            } 

            core.UINotebook.UnhideAllCells  = async (args, env) => {
                const uid   = await interpretate(args[0], env);
                CellWrapper.unhideAll(uid); 
            }

            core.UINotebook.ToggleCell = async (args, env) => {
                const uid   = await interpretate(args[0], env);
                CellWrapper.toggleCell(uid); 
            }

            core.UINotebook.ToggleInitGroup = async (args, env) => {
                const uid   = await interpretate(args[0], env);
                const state = await interpretate(args[1], env);

                CellWrapper.setInit(uid, state);
            }
            core.UINotebook.ToggleFade = async (args, env) => {
                const uid   = await interpretate(args[0], env);
                const state = await interpretate(args[1], env);

                CellWrapper.fadeCell(uid, state);
            }      
            core.UINotebook.ToggleLock = async (args, env) => {
                const uid   = await interpretate(args[0], env);
                const state = await interpretate(args[1], env);

                CellWrapper.lockCell(uid, state);
            }             

            core.UINotebook.ToggleInvisible = async (args, env) => {
                const uid   = await interpretate(args[0], env);
                const state = await interpretate(args[1], env);

                CellWrapper.vanishCell(uid, state);                
            }      


            core.UINotebook.RemoveCell = async (args, env) => {
                const uid = await interpretate(args[0], env);
                const ev = await interpretate(args[1], env);

                CellWrapper.remove(uid, ev);
            }        

            core.UINotebook.NewCell = async (args, env) => {
                const template = await interpretate(args[0], env);
                const store    = await interpretate(args[1], env);
                const list     = await interpretate(args[2], env);

                const ev     = await interpretate(args[3], env);

                const opts   = await core._getRules(args, env);

                new CellWrapper(template, store, list, ev, opts);
            };;
            <CellGeneratorScript/>;;
            <EvaluationBarScript/>;;
            <ControlsScript/>;;
            <HrScript/>;;
            <DropdownScript/>;;
        </script>
        <ExtensionTemplateInjection Template={"NotebookScript"}/>
    </div>
] 

destructor[notebook_, secret_, __] := With[{},
    Echo["Notebook.wlx >> Destroy"];

    Echo["!!!!Our socket number!!!!"];
    Echo[notebook["EvaluationContext", "KernelWebSocket"]];
    
    (* /* clean up secret and all handlers created */ *)
    EventRemove[secret];
    (* /* make sure that WebSocketQ flag is removed */ *)
    notebook["WebSocketQ"] = False;
    notebook["Opened"] = False;
];

(* /*  Exstension API */  *)
(* /*  Prolog, Epilog, Mesis, EventHandler */  *)

Component[OptionsPattern[]] := With[{
    secret = OptionValue["Secret"], 
    notebook = OptionValue["Notebook"], 
    event = OptionValue["Event"],
    parameters = OptionValue["Parameters"],
    controller     = OptionValue["Controls"],
    modals         = OptionValue["Modals"],
    log = OptionValue["Messanger"],
    kernels = OptionValue["Kernels"],

    electronQ = And[OptionValue["ElectronQ"], !OptionValue["IframeQ"]],

    appEvents = OptionValue["AppEvents"],

    ExtensionTemplateWrapper = OptionValue["ExtensionTemplateWrapper"],  
    ExtensionTemplateInjection = OptionValue["ExtensionTemplateInjection"], 
    ExternalEventHandlers = OptionValue["ExternalEventHandlers"],

    extensions = Sequence[
        "ExtensionTemplateWrapper" -> OptionValue["ExtensionTemplateWrapper"], 
        "ExtensionTemplateInjection" -> OptionValue["ExtensionTemplateInjection"]
    ]
},

    

    EventHandler[controller // EventClone, {
        "Save" -> Function[Null,
            If[TrueQ[notebook["_suspendBackups"]], notebook["_suspendBackups"] = .];
            EventFire[log, "Notebook:Sync:Started", True];

            With[{tt = EventFire[notebook, "OnBeforeSave", <|"Client" -> $Client, "Log"->log|>]},
                Then[tt, Function[Null,
                    Echo["SAVED!!!!!!!!!!!!!!!!!!!!!!!!!!!!"];
                    EventFire[log, "Notebook:Sync:Finished", True];
                    
                    Then[EventFire[controller, "DumpSave", notebook], Function[Null, 
                        EventFire[log, "Saved", ""];
                    ]];
                    
                ]];
            ];            
        ],

        "SaveAs" -> Function[path,
            If[TrueQ[notebook["_suspendBackups"]], notebook["_suspendBackups"] = .];
            EventFire[log, "Notebook:Sync:Started", True];
            With[{tt = EventFire[notebook, "OnBeforeSave", <|"Client" -> $Client, "Log"->log|>], client = $Client},

                Then[tt, Function[Null,
                    Echo["SAVEDAS!!!!!!!!!!!!!!!!!!!!!!!!!!!!"];
                    EventFire[log, "Notebook:Sync:Finished", True];
                    Then[EventFire[controller, "DumpSaveAs", <|"Notebook" -> notebook, "Client"-> client, "Path" -> URLDecode[path]|>], Function[Null, 
                        1+1
                    ]];
                ]];
            ];
        ],

        "ReopenAsQuickNote" -> Function[Null,
            EventFire[controller, "ReopenAsQuick", <|"Notebook" -> notebook, "Client"-> client, "Path" -> notebook["Path"]|>];
        ],

        "Backup" -> Function[data, Module[{}, With[{timer = AbsoluteTime[]},
            If[TrueQ[notebook["_suspendBackups"]], Return[Null, Module]];

            EventFire[log, "Notebook:Sync:Started", True];

            With[{tt = EventFire[notebook, "OnBeforeSave", <|"Client" -> data["Client"], "Log"->log|>]},
                Then[tt, Function[Null,
                    EventFire[log, "Notebook:Sync:Finished", True];
                    If[AbsoluteTime[] - timer > 5,
                        EventFire[log, "Warning", "Saving takes too long. Automatic backups were suspended."];
                        notebook["_suspendBackups"] = True;
                    ];

                    EventFire[controller, "DumpSaveTemporal", notebook];
                ]];
            ];            
        ]]],        

        "ChangeKernel" -> Function[p, Module[{kernel, client, payload = <||>},
            If[AssociationQ[p], payload = p];

            client = Lookup[payload, "Client", $Client];

            If[Length[ReleaseHold @ kernels] == 0, WebUISubmit[Alert["No Kernels are available"], client]; Return[] ];
         
            If[MemberQ[notebook["Properties"], "Evaluator"],
                notebook["Evaluator"] = .;
                notebook["WebSocketQ"] = False; 
                WebUISubmit[UINotebook["CreateServer"], client];
            ];

            With[{cli = client},

                If[KeyExistsQ[payload, "Kernel"],

                    kernel = GenericKernel`HashMap[payload["Kernel"]];
            
                    notebook["Evaluator"] = kernel["Container"];

                    If[TrueQ[kernel["ContainerReadyQ"]],
                        EventFire[notebook, "AquairedKernel", True];
                        Then[checkWSLink[notebook, cli, secret, log], Function[Null,
                            Echo["Kernel was changed!"];

                            ClearAll[client];
                            ClearAll[kernel]; ClearAll[payload];
                        ] ];
                    ,
                        Echo[kernel];
                        WebUISubmit[Alert["Initialization is not complete"], cli];
                    ];

                ,

                    requestKernel[notebook, kernels, modals, cli, Function[Null,
                        Then[checkWSLink[notebook, cli, secret, log], Function[Null,
                            Echo["Kernel was changed!"];

                            ClearAll[client];
                            ClearAll[kernel]; ClearAll[payload];
                        ] ];
                    ]];
                
                ];
            ];    
        ] ],

        "RestartKernel" -> Function[Null,
            Echo["Manual Kernel restart"];
            notebook["Evaluator"]["Kernel"] // GenericKernel`Restart;
        ],

        "ClearOutputs" -> Function[Null,
            Echo["ClearOutputs"];
            Delete /@ Select[notebook["Cells"], (cell`OutputCellQ[#] && #["Display"] =!= "markdown") &];
        ], 
        
        "UntrashCell" -> Function[Null,
            untrashCell[notebook, log, modals];
        ],
        
        "UnhideAllCells" -> Function[Null,
            WebUISubmit[UINotebook["UnhideAllCells", notebook["Hash"]], $Client];
        ],

        "ToggleFocusedCell" -> Function[Null,
            With[{focused = notebook["FocusedCell"]},
                If[MatchQ[focused, _cell`CellObj], WebUISubmit[UINotebook["ToggleCell", focused["Hash"]], $Client] ];
            ]
        ],

        "ToggleCell" -> Function[cell,
            With[{},
                WebUISubmit[UINotebook["ToggleCell", cell["Hash"]], $Client];
            ]
        ],        

        "DeleteFocusedCell" -> Function[Null,
            trashCell[notebook, notebook["FocusedCell"]];
            notebook["FocusedCell"] // Delete;
            If[notebook["Cells"] === {}, cell`CellObj["Notebook"->notebook, "Data"->""]];
        ],

        "DeleteACell" -> Function[cell,
            trashCell[notebook, cell];
            cell // Delete;
            If[notebook["Cells"] === {}, cell`CellObj["Notebook"->notebook, "Data"->""]];
        ],
        
        "EvaluateInitCells" -> Function[Null,
            notebook["CellsInitialized"] = True;
            ApplySync[Then, evaluateCell, {#, notebook, secret, log, kernels, $Client, modals, parameters, extensions} &/@ Select[notebook["Cells"], TrueQ[#["Props"]["InitGroup"]]&], Null]
        ],

        "EvaluateAllCells" -> Function[Null,
            notebook["CellsInitialized"] = True;
            ApplySync[Then, evaluateCell, {#, notebook, secret, log, kernels, $Client, modals, parameters, extensions} &/@ Select[notebook["Cells"], (#["Type"] === "Input" && !StringTake[#["Data"],3]===".md")& ], Null]
        ],

        "Abort" -> Function[Null,
            If[Length[Select[notebook["Cells"], (#["State"] =!= "Idle") &]] == 0,
                EventFire[log, "Warning", "No cells are under evaluation"]
                Return[];
            ];

            notebook["Evaluator"][$Aborted];
            Map[Function[cell,
                cell["State"] = "Idle";
                EventFire[cell, "State", "Idle"];
                EventFire[log, "Aborted", ""];
            ], Select[notebook["Cells"], (#["State"] =!= "Idle") &]];
        ],

        "NotebookCellEvaluate" -> Function[cell, evaluateCell[cell, notebook, secret, log, kernels, $Client, modals, parameters, extensions]],
        "NotebookCellEvaluateTemporal" -> Function[cell, evaluateCellFull[cell, notebook, secret, log, kernels, $Client, modals, parameters, extensions]],
        "NotebookCellProject" -> Function[cell, projectCell[cell, notebook, secret, log, kernels, $Client, modals, parameters, extensions]],
        "NotebookCellDataProject" -> Function[assoc, projectCellData[assoc["Cell"], Lookup[assoc, "EvaluatedQ", False], Lookup[assoc, "Data", assoc["Cell"]["Data"]], Lookup[assoc, "Display", "codemirror"], Lookup[assoc, "Hash", Null], Lookup[assoc, ImageSize, Automatic], Lookup[assoc, "Offscreen", False], notebook, secret, log, kernels, $Client, modals, parameters, extensions]],

        "NotebookQ" -> Function[Null,
            notebook
        ],

        ExtensionEvent[e_] :> (EventFire[appEvents, ExtensionEvent[e], notebook]&) 
    }];
    
    EventHandler[secret, {
        (* /* Add listeners and load cells */ *)

        "Load" -> Function[Null,
            Print["Notebook is about to be shown"];
            Echo[StringJoin["Connected using socket: ", $Client // ToString]];

            (* /* reset WS connection for sure, in a case of incorrect closed socket */*)
            notebook["WebSocketQ"] = False; 
            notebook["Opened"] = True;
            notebook["Socket"] = $Client;
            notebook["ModalsChannel"] = modals;
            notebook["MessangerChannel"] = Messanger;
            notebook["Controller"] = controller;

            (* /* Destructor */ *)
            With[{socket = EventClone[Global`$Client(*`*)]},
                EventHandler[socket, {"Closed" -> Function[Null,
                    Echo[">> SOCKET CLOSED!!!"];
                    EventRemove[socket];
                    EventFire[appEvents, "Notebook:Close", notebook];
                    EventFire[notebook, "OnClose", True];
                    
                    destructor[notebook, secret, parameters, extensions];
                ]}];
            ];

            (* /* Add all listeners to a **notebook** */ *)
            addListeners[notebook, secret, $Client, parameters, extensions];

            (* /* controllers events */ *)
            Then[EventFire[notebook, "OnBeforeLoad", <|"Client" -> $Client|>], Function[Null,
                (* /* Create a preliminary link to a Kernel */ *)
                WebUISubmit[UINotebook["CreateServer"], $Client];
    
                (* /* Establish WS Connection to a Kernel (if available) */ *)
                checkWSLink[notebook, $Client, secret, log];
    
                (* /* Restore cells */ *)
                If[Length[notebook["Cells"]] > 0, With[{n = notebook}, n["FocusedCell"] = n["Cells"][[1]]] ];
                restoreCells[notebook, secret, $Client, parameters, extensions];
    
                (*/* finish */*)
                EventFire[event, "Loaded", notebook];
                EventFire[controller, "NotebookShown", <|"Client"->$Client, "Notebook"->notebook|>];

                If[MemberQ[notebook["Properties"], "AutoconnectKernel"],
                    Echo["Autoconnecting provided kernel"];
                    
                    EventFire[controller, "ChangeKernel", <|"Client"->$Client, "Kernel"->notebook["AutoconnectKernel"]|>];
                    notebook["AutoconnectKernel"] = .;
                ];
            ]];

        ],

        "WebSocketConnected" -> Function[Null,
            Echo["Notebook.wlx >> WebSocket link to evaluation Kernel was established"];
            notebook["WebSocketQ"] = True;
            Then[EventFire[notebook, "OnWebSocketConnected", <|"Client" -> $Client|>], Function[Null,
                EventFire[notebook, "AfterWebSocketConnected", <|"Client" -> $Client|>]
            ]];
        ],

        "WebSocketLost" -> Function[Null,
            Echo["Notebook.wlx >> WebSocket link to evaluation Kernel was LOST"];
            notebook["WebSocketQ"] = False;
            EventFire[log, "WebSocket:Kernel:Lost", notebook];

            (* /* reset a preliminary link */ *)
            WebUISubmit[UINotebook["CreateServer"], $Client];
        ],

        "CallDropdown" -> Function[data,
            Echo[data];
        ], 

        "MakeInit" -> Function[uid,
            Echo["Toggle initialization cell..."];
            With[{cell = cell`HashMap[uid](*`*)},
                cell["Props"] = Join[cell["Props"], <|"InitGroup" -> !TrueQ[cell["Props", "InitGroup"]]|>];
                WebUISubmit[UINotebook["ToggleInitGroup", uid, TrueQ[cell["Props", "InitGroup"]]], $Client];
            ]
        ],

        "Lock" -> Function[uid,
            Echo["Lock cell..."];
            With[{cell = cell`HashMap[uid](*`*)},
                cell["Props"] = Join[cell["Props"], <|"Locked" -> !TrueQ[cell["Props", "Locked"]]|>];
                WebUISubmit[UINotebook["ToggleLock", uid, TrueQ[cell["Props", "Locked"]]], $Client];
            ]
        ],  

        "Hide" -> Function[uid,
            Echo["Fade cell..."];
            With[{cell = cell`HashMap[uid](*`*)},
                WebUISubmit[UINotebook["ToggleCell", cell["Hash"]], $Client];
            ]            
        ],         
        
        "Fade" -> Function[uid,
            Echo["Fade cell..."];
            With[{cell = cell`HashMap[uid](*`*)},
                cell["Props"] = Join[cell["Props"], <|"Fade" -> !TrueQ[cell["Props", "Fade"]]|>];
                WebUISubmit[UINotebook["ToggleFade", uid, TrueQ[cell["Props", "Fade"]]], $Client];
            ]
        ],         

        "ClearOutputs" -> Function[uid,
            Echo["Clear outputs"];
            With[{cell = cell`HashMap[uid](*`*)},
                Delete /@ cell`SelectCells[cell["Notebook"]["Cells"], Sequence[cell, __?cell`OutputCellQ]](*`*);
            ]
        ],

        "Vanish" -> Function[uid,
            If[!TrueQ[cell`HashMap[uid]["Invisible"](*`*)],
                With[{promise = Promise[]},
                    Then[promise, Function[result, 
                        If[TrueQ[result] || (result["response"] === 0),

                            With[{cell = cell`HashMap[uid](*`*)},
                                cell["Invisible"] = !TrueQ[cell["Invisible"]];
                                WebUISubmit[UINotebook["ToggleInvisible", uid, TrueQ[cell["Invisible"]]], $Client];
                            ];
                        ];
                    ]];

                    EventFire[modals, "MessageBox", <|
                        "Promise" -> promise, 
                        "title" -> "Make cell invisible", 
                        "message" -> "Invisible cell can only be changed in Expert mode",
                        "type" -> "question",
                        "buttons" -> {"Make", "Cancel"}
                    |>];

                ];
            ,
                With[{cell = cell`HashMap[uid](*`*)},
                    cell["Invisible"] = !TrueQ[cell["Invisible"]];
                    WebUISubmit[UINotebook["ToggleInvisible", uid, TrueQ[cell["Invisible"]]], $Client];
                ] 
            ];
        ],

        "Project" -> Function[uid, projectCell[cell`HashMap[uid](*`*), notebook, secret, log, kernels, $Client, modals, parameters, extensions]],

        "ProjectOrUpdate" -> Function[uid, projectCellOrUpdate[cell`HashMap[uid](*`*), notebook, secret, log, kernels, $Client, modals, parameters, extensions]],

        "UpdateCell" -> Function[payload,
            With[{cell = cell`HashMap[payload[[1]] ], content = payload[[2]] (*`*)},
                cell["Data"] = URLDecode[content];
                If[cell["Type"] == "Output",
                    Echo["Morphing..."];
                    cell["Type"] = "Input";
    
                    With[{template = CellGenerator[cell, $Client, parameters, extensions]},
                        WebUISubmit[UINotebook["Morph", payload[[1]], template, cell`Serialize[cell, "MetaOnly"->True]], $Client];
                    ];
                ];                
            ];   
        ],

        "RemoveCell" -> Function[uid,
            trashCell[notebook, cell`HashMap[uid]];
            cell`HashMap[uid] (*`*) //Delete;
            If[Select[notebook["Cells"], Function[c, !TrueQ[c["Invisible"]] && cell`InputCellQ[c]]] === {}, cell`CellObj["Notebook"->notebook, "Data"->""]];
        ],

        "SetProperty" -> Function[json,
            Print["Prop set..."];
            With[{obj = ImportString[json, "JSON"] // Association},
                If[AssociationQ[obj],
                    With[{c = cell`HashMap[obj["Cell"]]  (*`*), key = obj["Key"]},
                        c["Props", key] = obj["Value"];
                    ];
                ];
            ]
        ],
        
        "AddAfter" -> (addAfterHelper[notebook, ##]&),

        "AddAfterOutputs" -> Function[uid,
            (*/* request from the client with event provided */*)

            With[{o = cell`HashMap[uid] (*`*)},
                cell`CellObj["Notebook"->notebook, "Data"->"", "After"-> Sequence[o, ___?cell`OutputCellQ]];   
            ]
        ],        

        "AddBefore" -> (addBeforeHelper[notebook, ##]&),        

        Global`Forwarded[type_] (*`*):> Function[data,
            (*/* redirected events to Controls */*)
            Echo["Forward events >> "];
            If[AssociationQ[data],
                EventFire[controller, type, Join[data, <|"Notebook"->notebook|>]];
            ,
                EventFire[controller, type, data];
            ]   
            
        ],

        "Evaluate" -> Function[celluid, evaluateCell[cell`HashMap[celluid](*`*), notebook, secret, log, kernels, $Client, modals, parameters, extensions]]
    }];

    With[{nid = notebook["Hash"]},

        <main class="grow flex flex-col overflow-hidden dark:invert dark:hue-rotate-180 dark:contrast-75 dark:brightness-5 owin:bg-white dark:win:contrast-100 dark:win:shadow-0 win:m-4 win:mt-2 win:rounded-lg win:bg-white win:shadow linux:bg-white bg-g-trans" style="-webkit-app-region: no-drag">
            <KernelIndicator Notebook={notebook}/>
            <ExtensionTemplateInjection Template={"Notebook-Prolog"} Notebook={notebook} Event={secret} />
            <TopBar Notebook={notebook}/>
            <ExtensionTemplateWrapper Template={"CellsContainer"} Notebook={notebook} Event={secret}>
                <CellsContainer Parameters={parameters} Notebook={notebook} Event={secret}/>
            </ExtensionTemplateWrapper>
            <ExtensionTemplateInjection Template={"Notebook-Epilog"} Notebook={notebook} Event={secret} />

            <CellDropdown ElectronQ={electronQ} Parameters={parameters} Messager={log} Event={secret} ExtesionInjector={ExtensionTemplateInjection}/>
            <ElectronBinds Event={secret} Controls={controller}/>

            <ExtensionTemplateInjection Template={"Footer"} Modals={modals} Messager={log} Notebook={notebook} Event={secret} Controls={controller}/>
            <ExtensionTemplateInjection Template={"Scripts"} />

            <Script Parameters={parameters} ExtensionTemplateInjection={ExtensionTemplateInjection}/>
            
            <WebUIOnLoad Event={secret} Pattern={"Load"}/>
        </main>

    ]
]

Options[Component] = {"Parameters"->Null, "ElectronQ" -> False, "IframeQ"->False, "AppEvents"->"blacksheep", "Kernels"->{}, "Modals"->"", "Controls" ->"", "ControlsPort"->"", "Notebook"->Null, "Event"->"blackhole", "Messager"->"blackout", "Secret" :> CreateUUID[], "ExtensionTemplateWrapper"-> sequenceIdentity, "ExtensionTemplateInjection" -> emptyStringFunction, "ExternalEventHandlers" -> Null}
Options[Script] = {"Parameters"->Null, "ExtensionTemplateInjection" -> emptyStringFunction}

emptyStringFunction[x__] := ""
sequenceIdentity[first__, rulels___Rule] := first 

{Component, ""&}

